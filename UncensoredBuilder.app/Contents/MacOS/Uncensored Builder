#!/bin/bash
# Arranca el servidor en segundo plano (sin que tengas que abrir Terminal).
# El código siempre vive en Uncensored-LLM-appdata aunque la .app esté en ~/Applications.
set -euo pipefail

PORT="${UNCENSORED_BUILDER_PORT:-7788}"
RUNTIME="${UNCENSORED_BUILDER_HOME:-/Users/alvaro/Uncensored-LLM-appdata}"

if [[ ! -f "$RUNTIME/builder_server.py" ]]; then
  RUNTIME="$(cd "$(dirname "$0")/../../.." && pwd)"
fi
if [[ ! -f "$RUNTIME/builder_server.py" ]]; then
  RUNTIME="/Users/alvaro/Uncensored-LLM-appdata"
fi

if [[ ! -f "$RUNTIME/builder_server.py" ]]; then
  osascript -e 'display alert "Uncensored Builder" message "No se encontró builder_server.py en Uncensored-LLM-appdata." as critical'
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  osascript -e 'display alert "Uncensored Builder" message "Falta python3 en el PATH." as critical'
  exit 1
fi

cd "$RUNTIME"
VENV="$RUNTIME/venv"
if [[ ! -f "$VENV/bin/activate" ]]; then
  python3 -m venv "$VENV"
  "$VENV/bin/pip" install -q -r "$RUNTIME/requirements.txt"
fi
# shellcheck disable=SC1091
source "$VENV/bin/activate"

mkdir -p "$RUNTIME/memory"
PID_FILE="$RUNTIME/memory/builder_server.pid"
LOG_FILE="$RUNTIME/memory/builder_server.log"

# Builder viejo: rutas API inexistentes → 404 HTML en el navegador (no es fallo de OpenRouter en la nube).
if lsof -iTCP:"$PORT" -sTCP:LISTEN -P -n >/dev/null 2>&1; then
  bi=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 --max-time 5 "http://127.0.0.1:${PORT}/api/builder/install" 2>/dev/null || echo "000")
  gq=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 --max-time 5 "http://127.0.0.1:${PORT}/api/groq/test" 2>/dev/null || echo "000")
  orc=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 --max-time 5 "http://127.0.0.1:${PORT}/api/openrouter/test" 2>/dev/null || echo "000")
  cp=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 --max-time 5 "http://127.0.0.1:${PORT}/api/conversation-projects" 2>/dev/null || echo "000")
  if [[ "$gq" == "200" && "$orc" == "200" && "$bi" == "200" && "$cp" == "200" ]]; then
    open "http://127.0.0.1:${PORT}/dashboard"
    exit 0
  fi
  if [[ "$gq" == "404" || "$orc" == "404" || "$bi" == "404" || "$cp" == "404" ]]; then
    echo "$(date "+%Y-%m-%d %H:%M:%S") Reiniciando servidor antiguo (404 API: gq=$gq orc=$orc bi=$bi cp=$cp)…" >>"$LOG_FILE"
    pids=$(lsof -tiTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true)
    if [[ -n "${pids:-}" ]]; then
      kill $pids 2>/dev/null || true
      sleep 1.2
    fi
  else
    open "http://127.0.0.1:${PORT}/dashboard"
    exit 0
  fi
fi

nohup python3 "$RUNTIME/builder_server.py" >>"$LOG_FILE" 2>&1 &
echo $! >"$PID_FILE"
sleep 1.3
open "http://127.0.0.1:${PORT}/dashboard"
exit 0
